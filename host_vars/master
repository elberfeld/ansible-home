
debian_sources: 
  - "deb http://deb.debian.org/debian/ trixie main contrib non-free non-free-firmware"
  - "deb http://security.debian.org/debian-security trixie-security main contrib non-free non-free-firmware"
  - "deb http://deb.debian.org/debian/ trixie-updates main contrib non-free non-free-firmware"
  - "deb [signed-by=/etc/apt/proxmox-trixie.gpg] http://download.proxmox.com/debian/pve trixie pve-no-subscription"

debian_keys:
  - { url: "https://enterprise.proxmox.com/debian/proxmox-archive-keyring-trixie.gpg", file: "/etc/apt/proxmox-trixie.gpg" }


# Monitoring aktivieren 
alert:  
  load:
    warn: 4
    crit: 10
  containers: {}
  disks: 
    - { mountpoint: "/", warn: "50 GB", crit: "10 GB" }
    - { mountpoint: "/data", warn: "50 GB", crit: "10 GB" }


# Primäre IP Adressen des Hosts 
int_ip4: 10.5.0.100

# SAMBA Freigaben 
samba_shares_public:
  - { name: SharePublic, path: /data/SharePublic }

# SAMBA Freigaben 
samba_shares_private:
  - { name: SharePrivate, path: /data/SharePrivate }  
